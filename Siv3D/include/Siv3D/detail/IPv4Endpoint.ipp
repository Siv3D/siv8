# pragma once

namespace s3d
{
	////////////////////////////////////////////////////////////////
	//
	//	(constructor)
	//
	////////////////////////////////////////////////////////////////

	constexpr IPv4Endpoint::IPv4Endpoint(const IPv4Address& address, const port_type port) noexcept
		: m_address(address), m_port(port) {}

	////////////////////////////////////////////////////////////////
	//
	//	address, port
	//
	////////////////////////////////////////////////////////////////

	constexpr const IPv4Address& IPv4Endpoint::address() const noexcept
	{
		return m_address;
	}

	constexpr IPv4Endpoint::port_type IPv4Endpoint::port() const noexcept
	{
		return m_port;
	}

	////////////////////////////////////////////////////////////////
	//
	//	isAny
	//
	////////////////////////////////////////////////////////////////

	constexpr bool IPv4Endpoint::isAny() const noexcept
	{
		return (m_address.isAny() && (m_port == 0));
	}

	////////////////////////////////////////////////////////////////
	//
	//	swap
	//
	////////////////////////////////////////////////////////////////

	constexpr void IPv4Endpoint::swap(IPv4Endpoint& other) noexcept
	{
		m_address.swap(other.m_address);
		std::ranges::swap(m_port, other.m_port);
	}

	////////////////////////////////////////////////////////////////
	//
	//	hash
	//
	////////////////////////////////////////////////////////////////

	inline uint64 IPv4Endpoint::hash() const noexcept
	{
		return Hash(*this);
	}

	////////////////////////////////////////////////////////////////
	//
	//	Any
	//
	////////////////////////////////////////////////////////////////

	constexpr IPv4Endpoint IPv4Endpoint::Any() noexcept
	{
		return{ IPv4Address::Any(), 0 };
	}

	////////////////////////////////////////////////////////////////
	//
	//	Localhost
	//
	////////////////////////////////////////////////////////////////

	constexpr IPv4Endpoint IPv4Endpoint::Localhost(const port_type port) noexcept
	{
		return{ IPv4Address::Localhost(), port };
	}
}
